{
  "_version": "1.83.0",
  "sap.app": {
    "id": "app.tallyapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "5ef8e404-4384-485f-828a-03ec910e9032"
    },
    "crossNavigation": {
      "inbounds": {
        "tally-display": {
          "semanticObject": "tally",
          "action": "display",
          "title": "{{tally-display.flpTitle}}",
          "subTitle": "{{tally-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "dataSources": {
      "TallyCapService": {
        "uri": "/odata/v4/tally/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "app.tallyapp.i18n.i18n",
          "fallbackLocale": ""
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "app.tallyapp.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "async": true,
        "transition": "slide"
      },
      "routes": [
        {
          "name": "Login",
          "pattern": "",
          "target": [
            "TargetLogin"
          ]
        },
        {
          "name": "Credentials",
          "pattern": "credentials",
          "target": [
            "TargetCredentials"
          ]
        },
        {
          "name": "RouteView1",
          "pattern": "dashboard",
          "target": [
            "TargetView1"
          ]
        }
      ],
      "targets": {
        "TargetLogin": {
          "viewType": "XML",
          "viewId": "Login",
          "viewName": "Login",
          "controlAggregation": "pages",
          "controlId": "app"
        },
        "TargetCredentials": {
          "viewType": "XML",
          "viewId": "Credentials",
          "viewName": "Credentials",
          "controlAggregation": "pages",
          "controlId": "app"
        },
        "TargetView1": {
          "viewType": "XML",
          "viewId": "View1",
          "viewName": "View1",
          "controlAggregation": "pages",
          "controlId": "app"
        }
      }
    },
    "rootView": {
      "viewName": "app.tallyapp.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}