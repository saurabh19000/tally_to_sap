<mvc:View
    controllerName="app.tallyapp.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        id="dashboardPage"
        title="Tally Intelligence Dashboard"
        busy="{/busy}"
        busyIndicatorDelay="0"
        showHeader="true"
        backgroundDesign="List">

        <customHeader>
            <OverflowToolbar>
                <!-- Dashboard Header Logo -->
                <core:Icon
                    src="sap-icon://building"
                    size="1.6rem"
                    color="#0070F2"
                    class="sapUiSmallMarginEnd"/>
                <Title
                    text="Tally Intelligence Dashboard"
                    level="H2"
                    titleStyle="H4"/>
                <ToolbarSpacer/>
                <!-- Company Context Selector -->
                <Select 
                    id="companySelect" 
                    items="{/companies}" 
                    selectedKey="{/selectedCompany}" 
                    change=".onCompanyChange"
                    class="sapUiSmallMarginEnd"
                    tooltip="Select Company Context"
                    width="auto"
                    maxWidth="200px">
                    <core:Item key="{key}" text="{text}" />
                </Select>
                <!-- Last Refreshed Status -->
                <Label
                    text="{/lastRefreshed}"
                    design="Bold"
                    class="sapUiSmallMarginEnd"/>
                <!-- Action Buttons -->
                <Button
                    id="fetchBtpBtn"
                    text="Fetch from BTP"
                    icon="sap-icon://cloud"
                    type="Ghost"
                    press=".onFetchBtp"
                    class="sapUiTinyMarginEnd"
                    tooltip="Manually trigger a sync from SAP BTP"/>
                <Button
                    id="syncBtn"
                    text="Refresh UI"
                    icon="sap-icon://synchronize"
                    type="Emphasized"
                    press=".onRefresh"
                    tooltip="Refresh current dashboard data"/>
                <Button
                    id="settingsBtn"
                    text="BTP Settings"
                    icon="sap-icon://settings"
                    type="Ghost"
                    press=".onGoToCredentials"
                    tooltip="Update BTP credentials"/>
                <Button
                    id="logoutBtn"
                    text="Logout"
                    icon="sap-icon://log"
                    type="Ghost"
                    press=".onLogout"
                    tooltip="Sign out"/>
            </OverflowToolbar>
        </customHeader>

        <content>

            <!-- Data Source Summary Panel -->
            <Panel
                id="headerPanel"
                backgroundDesign="Solid"
                class="sapUiSmallMargin sapUiShadowLevel1">

                <headerToolbar>
                    <Toolbar height="3rem">
                        <core:Icon
                            src="sap-icon://business-objects-experience"
                            size="1rem"
                            color="#0070F2"
                            class="sapUiSmallMarginEnd"/>
                        <Title
                            text="Data Source Summary"
                            level="H3"
                            titleStyle="H5"/>
                        <ToolbarSpacer/>
                    </Toolbar>
                </headerToolbar>

                <HBox
                    wrap="Wrap"
                    justifyContent="SpaceBetween"
                    alignItems="Center"
                    class="sapUiSmallMargin">

                    <VBox class="metricTile sapUiSmallMarginBottom">
                        <Label text="Latest Sync Company" class="sapUiTinyMarginBottom"/>
                        <ObjectStatus text="{/company}" state="Information" icon="sap-icon://home"/>
                    </VBox>

                    <VBox class="metricTile sapUiSmallMarginBottom">
                        <Label text="Ledgers" class="sapUiTinyMarginBottom"/>
                        <ObjectStatus text="{/totalLedgers}" state="Success" icon="sap-icon://account"/>
                    </VBox>

                    <VBox class="metricTile sapUiSmallMarginBottom">
                        <Label text="Vouchers" class="sapUiTinyMarginBottom"/>
                        <ObjectStatus text="{/totalVouchers}" state="Warning" icon="sap-icon://receipt"/>
                    </VBox>

                    <VBox class="metricTile sapUiSmallMarginBottom">
                        <Label text="Stock Items" class="sapUiTinyMarginBottom"/>
                        <ObjectStatus text="{/totalStockItems}" state="Error" icon="sap-icon://product"/>
                    </VBox>

                    <VBox class="metricTile sapUiSmallMarginBottom">
                        <Label text="Total System Records" class="sapUiTinyMarginBottom"/>
                        <ObjectStatus text="{/totalRecords}" state="None" icon="sap-icon://database"/>
                    </VBox>

                    <VBox class="metricTile sapUiSmallMarginBottom">
                        <Label text="Latest Sync ID" class="sapUiTinyMarginBottom"/>
                        <ObjectStatus text="{/syncId}" state="None"/>
                    </VBox>
                </HBox>
            </Panel>

            <!-- Tab Bar for Data Views -->
            <IconTabBar
                id="tabBar"
                class="sapUiSmallMarginBeginEnd"
                select=".onTabSelect"
                expanded="{device>/system/phone}"
                selectedKey="{/tab}">

                <items>
                    <!-- Sync History Tab -->
                    <IconTabFilter key="SyncHistory" text="Sync History" icon="sap-icon://history">
                        <Panel backgroundDesign="Solid" class="sapUiSmallMargin sapUiShadowLevel1">
                            <headerToolbar>
                                <Toolbar>
                                    <core:Icon src="sap-icon://list" size="1rem" class="sapUiSmallMarginEnd"/>
                                    <Title text="BTP Synchronization History" level="H3" titleStyle="H6"/>
                                    <ToolbarSpacer/>
                                    <SearchField
                                        id="syncSearchField"
                                        placeholder="Search by Sync ID…"
                                        class="searchFieldResponsive"
                                        liveChange=".onSearch"
                                        search=".onSearch"
                                        showRefreshButton="false"/>
                                </Toolbar>
                            </headerToolbar>

                            <Table
                                id="syncTable"
                                items="{path: '/syncs'}"
                                growing="true"
                                growingThreshold="10"
                                alternateRowColors="true"
                                sticky="ColumnHeaders"
                                noDataText="No synchronization history found."
                                mode="SingleSelectMaster"
                                selectionChange=".onSyncSelect">

                                <columns>
                                    <Column width="15%" minScreenWidth="Tablet"><Text text="Version ID"/></Column>
                                    <Column width="30%"><Text text="Sync ID (BTP)"/></Column>
                                    <Column width="15%" minScreenWidth="Tablet"><Text text="Company"/></Column>
                                    <Column width="15%" minScreenWidth="Tablet"><Text text="Data Type"/></Column>
                                    <Column width="10%" hAlign="End" minScreenWidth="Tablet"><Text text="Records"/></Column>
                                    <Column width="15%" hAlign="Center" minScreenWidth="Tablet"><Text text="Pushed At"/></Column>
                                </columns>

                                <items>
                                    <ColumnListItem type="Active">
                                        <Text text="Version {versionId}" design="Bold"/>
                                        <Text text="{syncId}" wrapping="false"/>
                                        <ObjectStatus text="{company}" state="Information"/>
                                        <Label text="{dataType}" design="Bold"/>
                                        <ObjectNumber number="{totalRecords}" unit="docs" state="Success"/>
                                        <Text text="{path: 'pushedAt', formatter: '.formatDate'}"/>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </Panel>
                    </IconTabFilter>

                    <!-- Ledgers Tab -->
                    <IconTabFilter key="Ledgers" text="Ledgers" icon="sap-icon://account">
                        <Panel backgroundDesign="Solid" class="sapUiSmallMargin sapUiShadowLevel1">
                            <headerToolbar>
                                <Toolbar>
                                    <core:Icon src="sap-icon://shield" size="1rem" color="#0070F2" class="sapUiSmallMarginEnd"/>
                                    <Title text="Ledger Register" level="H3" titleStyle="H6"/>
                                    <ToolbarSpacer/>
                                    <SearchField
                                        id="searchField"
                                        placeholder="Search by ledger name…"
                                        class="searchFieldResponsive"
                                        liveChange=".onSearch"
                                        search=".onSearch"
                                        showRefreshButton="false"/>
                                </Toolbar>
                            </headerToolbar>

                            <Table
                                id="ledgerTable"
                                items="{path: '/ledgers'}"
                                growing="true"
                                growingThreshold="10"
                                alternateRowColors="true"
                                sticky="ColumnHeaders"
                                noDataText="No ledger records found."
                                mode="None">

                                <columns>
                                    <Column width="15%"><Text text="Ledger Name"/></Column>
                                    <Column width="12%" minScreenWidth="Tablet"><Text text="Parent Group"/></Column>
                                    <Column width="10%" minScreenWidth="Tablet"><Text text="GSTIN"/></Column>
                                    <Column width="10%" hAlign="End"><Text text="Closing"/></Column>
                                    <Column width="12%" hAlign="Center" minScreenWidth="Tablet"><Text text="Sync Date"/></Column>
                                    <Column width="8%" hAlign="Center" minScreenWidth="Phone"><Text text="Details"/></Column>
                                </columns>

                                <items>
                                    <ColumnListItem
                                        type="Active"
                                        highlight="{path: 'closingBalance', formatter: '.formatBalanceState'}">
                                        <ObjectIdentifier title="{name}" titleActive="false"/>
                                        <Text text="{parentGroup}" wrapping="false"/>
                                        <Text text="{gstin}" wrapping="false"/>
                                        <ObjectNumber number="{path: 'closingBalance', formatter: '.formatBalance'}" state="{path: 'closingBalance', formatter: '.formatBalanceState'}" emphasized="true"/>
                                        <Text text="{path: 'syncDate', formatter: '.formatDate'}" wrapping="false"/>
                                        <Button icon="sap-icon://hint" type="Transparent" press=".onViewDetails" tooltip="View all dynamic fields"/>
                                    </ColumnListItem>
                                </items>
                            </Table>

                            <Toolbar height="2.5rem">
                                <core:Icon src="sap-icon://connected" color="#107E3E" class="sapUiSmallMarginEnd"/>
                                <Label text="Total Unique Ledgers:"/>
                                <ToolbarSpacer/>
                                <Label text="{= ${/ledgers}.length + ' records'}" design="Bold"/>
                            </Toolbar>
                        </Panel>
                    </IconTabFilter>

                    <!-- Vouchers Tab -->
                    <IconTabFilter key="Vouchers" text="Vouchers" icon="sap-icon://receipt">
                        <Panel backgroundDesign="Solid" class="sapUiSmallMargin sapUiShadowLevel1">
                            <headerToolbar>
                                <Toolbar>
                                    <core:Icon src="sap-icon://table-chart" size="1rem" class="sapUiSmallMarginEnd"/>
                                    <Title text="Voucher Register" level="H3" titleStyle="H6"/>
                                    <ToolbarSpacer/>
                                    <SearchField
                                        id="voucherSearchField"
                                        placeholder="Search by party name…"
                                        class="searchFieldResponsive"
                                        liveChange=".onSearch"
                                        search=".onSearch"
                                        showRefreshButton="false"/>
                                </Toolbar>
                            </headerToolbar>

                            <Table
                                id="voucherTable"
                                items="{path: '/vouchers'}"
                                growing="true"
                                growingThreshold="10"
                                alternateRowColors="true"
                                sticky="ColumnHeaders"
                                noDataText="No voucher records found."
                                mode="None">

                                <columns>
                                    <Column width="10%" minScreenWidth="Tablet"><Text text="Date"/></Column>
                                    <Column width="11%"><Text text="Voucher Type"/></Column>
                                    <Column width="8%" minScreenWidth="Tablet"><Text text="No."/></Column>
                                    <Column width="12%"><Text text="Party Name"/></Column>
                                    <Column width="13%" minScreenWidth="Tablet"><Text text="Narration"/></Column>
                                    <Column width="12%" hAlign="End"><Text text="Amount"/></Column>
                                    <Column width="8%" hAlign="Center" minScreenWidth="Phone"><Text text="Details"/></Column>
                                </columns>

                                <items>
                                    <ColumnListItem type="Active">
                                        <Text text="{voucherDate}" wrapping="false"/>
                                        <Label text="{voucherType}" design="Bold"/>
                                        <Text text="{voucherNumber}" wrapping="false"/>
                                        <ObjectIdentifier title="{partyName}" titleActive="false"/>
                                        <Text text="{narration}" wrapping="false" maxLines="1"/>
                                        <ObjectNumber number="{path: 'netAmount', formatter: '.formatBalance'}" state="{path: 'netAmount', formatter: '.formatBalanceState'}" emphasized="true"/>
                                        <Button icon="sap-icon://hint" type="Transparent" press=".onViewDetails" tooltip="View all dynamic fields"/>
                                    </ColumnListItem>
                                </items>
                            </Table>

                            <Toolbar height="2.5rem">
                                <core:Icon src="sap-icon://connected" color="#107E3E" class="sapUiSmallMarginEnd"/>
                                <Label text="Total System Vouchers:"/>
                                <ToolbarSpacer/>
                                <Label text="{= ${/vouchers}.length + ' records'}" design="Bold"/>
                            </Toolbar>
                        </Panel>
                    </IconTabFilter>

                    <!-- Stock Items Tab -->
                    <IconTabFilter key="StockItems" text="Stock Items" icon="sap-icon://inventory">
                        <Panel backgroundDesign="Solid" class="sapUiSmallMargin sapUiShadowLevel1">
                            <headerToolbar>
                                <Toolbar>
                                    <core:Icon src="sap-icon://table-chart" size="1rem" class="sapUiSmallMarginEnd"/>
                                    <Title text="Stock Register" level="H3" titleStyle="H6"/>
                                    <ToolbarSpacer/>
                                    <SearchField
                                        id="stockSearchField"
                                        placeholder="Search by stock name…"
                                        class="searchFieldResponsive"
                                        liveChange=".onSearch"
                                        search=".onSearch"
                                        showRefreshButton="false"/>
                                </Toolbar>
                            </headerToolbar>

                            <Table
                                id="stockTable"
                                items="{path: '/stockItems'}"
                                growing="true"
                                growingThreshold="10"
                                alternateRowColors="true"
                                sticky="ColumnHeaders"
                                noDataText="No stock records found."
                                mode="None">

                                <columns>
                                    <Column width="15%"><Text text="Stock Name"/></Column>
                                    <Column width="10%" minScreenWidth="Tablet"><Text text="Category"/></Column>
                                    <Column width="8%" hAlign="End"><Text text="Rate"/></Column>
                                    <Column width="8%" hAlign="End"><Text text="Qty"/></Column>
                                    <Column width="8%" minScreenWidth="Tablet"><Text text="Unit"/></Column>
                                    <Column width="10%" hAlign="End"><Text text="Amount"/></Column>
                                    <Column width="13%" hAlign="Center" minScreenWidth="Tablet"><Text text="Sync Date"/></Column>
                                    <Column width="8%" hAlign="Center" minScreenWidth="Phone"><Text text="Details"/></Column>
                                </columns>

                                <items>
                                    <ColumnListItem type="Active">
                                        <ObjectIdentifier title="{stockName}" titleActive="false"/>
                                        <Text text="{category}" wrapping="false"/>
                                        <Text text="{rate}"/>
                                        <Text text="{quantity}"/>
                                        <Text text="{unit}" wrapping="false"/>
                                        <ObjectNumber number="{path: 'amount', formatter: '.formatBalance'}" state="None"/>
                                        <Text text="{path: 'syncDate', formatter: '.formatDate'}" wrapping="false"/>
                                        <Button icon="sap-icon://hint" type="Transparent" press=".onViewDetails" tooltip="View all dynamic fields"/>
                                    </ColumnListItem>
                                </items>
                            </Table>

                            <Toolbar height="2.5rem">
                                <core:Icon src="sap-icon://connected" color="#107E3E" class="sapUiSmallMarginEnd"/>
                                <Label text="Stock Items"/>
                                <ToolbarSpacer/>
                                <Label text="{= ${/stockItems}.length + ' records'}" design="Bold"/>
                            </Toolbar>
                        </Panel>
                    </IconTabFilter>
                </items>
            </IconTabBar>

        </content>

        <footer>
            <Bar design="Footer">
                <contentLeft>
                    <core:Icon src="sap-icon://building" color="#0070F2"/>
                    <Label text="  Tally Intelligence · Powered by SAP BTP" design="Bold" class="sapUiSmallMarginBegin"/>
                </contentLeft>
                <contentRight>
                    <Label text="Tally Intelligence Dashboard · INR · India"/>
                </contentRight>
            </Bar>
        </footer>

    </Page>
</mvc:View>
