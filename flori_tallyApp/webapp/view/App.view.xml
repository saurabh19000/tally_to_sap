    controllerName="app.tallyapp.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <!--
        App.view.xml — ROOT SHELL (DO NOT ADD CONTENT HERE)

        manifest.json → rootView loads THIS file as the outer shell.
        manifest.json → routing.config.controlId = "app"
