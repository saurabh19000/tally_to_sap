<mvc:View
    controllerName="app.tallyapp.controller.Login"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">

    <Page
        id="loginPage"
        showHeader="false"
        enableScrolling="false"
        class="loginPage">

        <HBox
            class="loginWrapper"
            justifyContent="Center"
            alignItems="Center"
            height="100%">

            <!-- Main Login Card -->
            <HBox
                class="loginContainer"
                renderType="Bare">

                <!-- LEFT BRANDING PANEL -->
                <VBox
                    class="brandingPanel"
                    justifyContent="Center"
                    alignItems="Center">

                    <core:Icon
                        src="sap-icon://building"
                        size="5rem"
                        color="white"
                        class="sapUiMediumMarginBottom"/>

                    <Title
                        text="Tally Intelligence Dashboard"
                        level="H2"
                        class="brandingTitle"/>

                    <Text
                        text="Real-time Tally analytics and SAP BTP integration"
                        class="brandingSubtitle"/>

                </VBox>

                <!-- RIGHT LOGIN PANEL -->
                <VBox class="loginPanel">

                    <!-- Logo & Heading -->
                    <VBox
                        alignItems="Center"
                        class="sapUiLargeMarginBottom">

                        <core:Icon
                            src="sap-icon://building"
                            size="3rem"
                            color="#0A6ED1"
                            class="sapUiSmallMarginBottom"/>

                        <Title
                            text="TALLY INTELLIGENCE"
                            level="H2"
                            textAlign="Center"/>

                        <Text
                            text="Powered by SAP BTP"
                            textAlign="Center"/>

                    </VBox>

                    <!-- EMAIL -->

                    <Label
                        text="Email"
                        required="true"
                        labelFor="emailInput"/>

                    <Input
                        id="emailInput"
                        type="Email"
                        placeholder="Enter your email address"
                        width="100%"
                        liveChange=".onEmailChange"/>

                    <VBox width="100%">

    <Button
        id="verifyEmailBtn"
        text="Verify"
        type="Emphasized"
        width="100%"
        press=".onVerifyEmail"/>

    <!-- Reserved space for status to prevent layout shift -->
    <VBox height="70px" justifyContent="Center">
        <MessageStrip
            id="emailStatusText"
            visible="false"
            showIcon="true"
            showCloseButton="false"/>
    </VBox>

</VBox>

                    <!-- PASSWORD -->
    
                    <Label
                        text="Password"
                        required="true"
                        labelFor="passwordInput"
                        class="sapUiLargeMarginTop"/>

                    <Input
                        id="passwordInput"
                        type="Password"
                        placeholder="Enter your password"
                        width="100%"
                        enabled="false"
                        liveChange=".onPasswordChange"/>

                    <Button
                        id="loginBtn"
                        text="Sign In"
                        type="Emphasized"
                        press=".onLogin"
                        enabled="false"
                        width="100%"
                        class="sapUiMediumMarginTop"/>

                    <Text
                        id="passwordStatusText"
                        visible="false"
                        class="sapUiSmallMarginTop"/>

                    <Text
                        text="Secure access to Tally data"
                        class="footerText sapUiLargeMarginTop"/>

                    <BusyIndicator
                        id="loginBusy"
                        visible="false"
                        text="Please wait..."
                        size="1.5rem"
                        class="sapUiMediumMarginTop"/>

                </VBox>

            </HBox>

        </HBox>

    </Page>

</mvc:View> 