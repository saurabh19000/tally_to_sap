<mvc:View
    controllerName="app.tallyapp.controller.Login"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">

    <Page
        id="loginPage"
        showHeader="false"
        enableScrolling="true"
        backgroundDesign="Solid">

        <HBox
            justifyContent="Center"
            alignItems="Center"
            height="100%">

            <VBox
                class="cardShadowLogin sapUiMediumMarginBeginEnd sapUiMediumMarginTopBottom">

                <!-- App Logo -->
                <VBox class="sapUiSmallMarginTop" alignItems="Center">
                    <core:Icon
                        src="sap-icon://building"
                        size="3rem"
                        color="#0070F2"
                        class="sapUiSmallMarginBottom"/>
                    <Title
                        text="TALLY INTELLIGENCE"
                        level="H2"
                        titleStyle="H2"
                        class="sapUiTinyMarginBottom"
                        textAlign="Center"/>
                    <Title
                        text="Dashboard"
                        level="H1"
                        titleStyle="H1"
                        class="sapUiTinyMarginBottom"
                        textAlign="Center"/>
                    <Text
                        text="Powered by SAP BTP"
                        class="sapUiSmallMarginBottom"
                        textAlign="Center"/>
                </VBox>

                <VBox class="sapUiMediumMarginTop sapUiLargeMarginBottom" width="100%">

                    <Label text="Email" labelFor="emailInput" required="true" design="Bold" class="sapUiSmallMarginBottom"/>
                    <Input
                        id="emailInput"
                        type="Email"
                        placeholder="Enter your email address"
                        width="100%"
                        liveChange=".onEmailChange"/>
                    <Button
                        id="verifyEmailBtn"
                        text="Verify"
                        type="Emphasized"
                        press=".onVerifyEmail"
                        width="100%"
                        class="sapUiTinyMarginTop"/>

                    <Text
                        id="emailStatusText"
                        visible="false"
                        class="sapUiTinyMarginTop sapUiSmallMarginBottom"/>

                    <Label text="Password" labelFor="passwordInput" required="true" design="Bold" class="sapUiLargeMarginTop sapUiSmallMarginBottom"/>
                    <Input
                        id="passwordInput"
                        type="Password"
                        placeholder="Enter your password"
                        width="100%"
                        enabled="false"
                        liveChange=".onPasswordChange"/>
                    <Button
                        id="loginBtn"
                        text="Sign In"
                        type="Emphasized"
                        press=".onLogin"
                        enabled="false"
                        width="100%"
                        class="sapUiTinyMarginTop"/>

                    <Text
                        id="passwordStatusText"
                        visible="false"
                        class="sapUiTinyMarginTop sapUiSmallMarginBottom"/>

                </VBox>

                <!-- Footer text -->
                <Text
                    text="Secure access to Tally data"
                    class="sapUiSmallMarginBottom"
                    textAlign="Center"/>

                <BusyIndicator
                    id="loginBusy"
                    visible="false"
                    class="sapUiMediumMarginBottom"
                    size="1.5rem"
                    text="Please wait..."/>

            </VBox>

        </HBox>

    </Page>

</mvc:View>
