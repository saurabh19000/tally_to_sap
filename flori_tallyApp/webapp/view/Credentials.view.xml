<mvc:View
    controllerName="app.tallyapp.controller.Credentials"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">

    <Page
        id="credsPage"
        showHeader="false"
        enableScrolling="false"
        backgroundDesign="Solid">

        <HBox
            justifyContent="Center"
            alignItems="Center"
            height="100%">

            <VBox
                class="cardShadow sapUiMediumMarginBeginEnd">

                <!-- Header -->
                <VBox alignItems="Center" class="sapUiSmallMarginBottom">
                    <core:Icon
                        src="sap-icon://settings"
                        size="2.5rem"
                        color="#0070F2"
                        class="sapUiTinyMarginBottom"/>
                    <Title
                        text="BTP Credentials"
                        level="H2"
                        titleStyle="H2"/>
                    <Text
                        text="Configure your SAP BTP service key to connect the dashboard"
                        textAlign="Center"
                        class="sapUiTinyMarginTop"/>
                </VBox>

                <VBox width="100%" class="sapUiSmallMarginTopBottom">

                    <Button
                        id="uploadBtn"
                        text="Upload Credentials File"
                        icon="sap-icon://upload"
                        type="Default"
                        width="100%"
                        press=".onUploadFile"
                        class="sapUiSmallMarginBottom"/>

                    <Text
                        text="— or enter manually —"
                        textAlign="Center"
                        class="sapUiTinyMarginBottom"/>

                    <Label text="Client ID" labelFor="clientIdInput" required="true" design="Bold" class="sapUiTinyMarginTop sapUiTinyMarginBottom"/>
                    <Input
                        id="clientIdInput"
                        placeholder="sb-xxxxx...!bxxx|it-rt-xxxxx!bxxx"
                        width="100%"
                        liveChange=".onInputChange"/>

                    <Label text="Client Secret" labelFor="clientSecretInput" required="true" design="Bold" class="sapUiTinyMarginTop sapUiTinyMarginBottom"/>
                    <HBox width="100%">
                        <Input
                            id="clientSecretInput"
                            type="Password"
                            placeholder="Enter your client secret"
                            width="100%"
                            liveChange=".onInputChange"
                            class="sapUiSmallMarginEnd"/>
                        <Button
                            id="pwdToggleBtn"
                            icon="sap-icon://show"
                            type="Transparent"
                            press=".onTogglePassword"
                            tooltip="Show password"/>
                    </HBox>

                    <Label text="Token URL" labelFor="tokenUrlInput" required="true" design="Bold" class="sapUiTinyMarginTop sapUiTinyMarginBottom"/>
                    <Input
                        id="tokenUrlInput"
                        type="Url"
                        placeholder="https://xxxxx.authentication.us10.hana.ondemand.com/oauth/token"
                        width="100%"
                        liveChange=".onInputChange"/>

                    <Label text="Runtime URL (CPI API Base)" labelFor="cpiBaseInput" required="true" design="Bold" class="sapUiTinyMarginTop sapUiTinyMarginBottom"/>
                    <Input
                        id="cpiBaseInput"
                        type="Url"
                        placeholder="https://xxxxx.it-cpitrial05-rt.cfapps.us10-001.hana.ondemand.com"
                        width="100%"
                        liveChange=".onInputChange"/>

                    <Button
                        id="saveCredsBtn"
                        text="Save &amp; Continue to Dashboard"
                        icon="sap-icon://save"
                        type="Emphasized"
                        width="100%"
                        press=".onSaveCredentials"
                        class="sapUiMediumMarginTop"/>

                    <Text
                        id="credsStatusText"
                        visible="false"
                        class="sapUiTinyMarginTop"
                        width="100%"/>

                </VBox>

                <BusyIndicator
                    id="credsBusy"
                    visible="false"
                    class="sapUiTinyMarginTop"
                    size="1.5rem"
                    text="Validating credentials..."/>

            </VBox>

        </HBox>

    </Page>

</mvc:View>
