<mvc:View
    controllerName="app.tallyapp.controller.Credentials"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">

    <Page
        id="credsPage"
        showHeader="false"
        enableScrolling="true">

        <HBox
            justifyContent="Center"
            alignItems="Center"
            class="sapUiLargeMarginTop"
            height="100%">

            <VBox
                class="responsiveCard sapUiMediumMarginBeginEnd">

                <core:Icon
                    src="sap-icon://key"
                    size="3.5rem"
                    color="#0070F2"
                    class="sapUiLargeMarginBottom sapUiLargeMarginTop"/>

                <Title
                    text="BTP Credentials"
                    level="H1"
                    titleStyle="H2"
                    class="sapUiMediumMarginBottom"
                    textAlign="Center"/>

                <Text
                    text="Enter your SAP BTP service key credentials to connect to the cloud backend."
                    class="sapUiSmallMarginBottom"
                    textAlign="Center"/>

                <Text
                    text="You can upload a .txt or .env file with the credentials, or enter them manually."
                    class="sapUiSmallMarginBottom"
                    textAlign="Center"/>

                <VBox class="sapUiLargeMarginTop" width="100%">

                    <Button
                        id="uploadBtn"
                        text="Upload Credentials File"
                        icon="sap-icon://upload"
                        type="Default"
                        width="100%"
                        press=".onUploadFile"
                        class="sapUiMediumMarginBottom"/>

                    <Text
                        text="— or enter manually —"
                        textAlign="Center"
                        class="sapUiSmallMarginBottom"/>

                    <Label text="BTP Client ID" labelFor="clientIdInput" required="true" design="Bold" class="sapUiSmallMarginBottom"/>
                    <Input
                        id="clientIdInput"
                        placeholder="sb-xxxxx...!bxxx|it-rt-xxxxx!bxxx"
                        width="100%"
                        liveChange=".onInputChange"
                        class="sapUiSmallMarginBottom"/>

                    <Label text="BTP Client Secret" labelFor="clientSecretInput" required="true" design="Bold" class="sapUiSmallMarginBottom"/>
                    <HBox width="100%">
                        <Input
                            id="clientSecretInput"
                            type="Password"
                            placeholder="xxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx$xXxXxXxXxXxXxXxXxXxXxXxXxXxXxXxXxXx"
                            width="100%"
                            liveChange=".onInputChange"
                            class="sapUiSmallMarginEnd"/>
                        <Button
                            id="pwdToggleBtn"
                            icon="sap-icon://show"
                            type="Transparent"
                            press=".onTogglePassword"
                            tooltip="Show password"
                            class="sapUiSmallMarginTopEnd"/>
                    </HBox>

                    <Label text="BTP Token URL" labelFor="tokenUrlInput" required="true" design="Bold" class="sapUiSmallMarginBottom"/>
                    <Input
                        id="tokenUrlInput"
                        type="Url"
                        placeholder="https://xxxxx.authentication.us10.hana.ondemand.com/oauth/token"
                        width="100%"
                        liveChange=".onInputChange"
                        class="sapUiSmallMarginBottom"/>

                    <Label text="BTP Runtime URL" labelFor="cpiBaseInput" required="true" design="Bold" class="sapUiSmallMarginBottom"/>
                    <Input
                        id="cpiBaseInput"
                        type="Url"
                        placeholder="https://xxxxx.it-cpitrial05-rt.cfapps.us10-001.hana.ondemand.com"
                        width="100%"
                        liveChange=".onInputChange"
                        class="sapUiMediumMarginBottom"/>

                    <Button
                        id="saveCredsBtn"
                        text="Save &amp; Continue to Dashboard"
                        type="Emphasized"
                        width="100%"
                        press=".onSaveCredentials"
                        visible="true"/>

                    <Text
                        id="credsStatusText"
                        visible="false"
                        class="sapUiTinyMarginTop"
                        width="100%"/>

                    <BusyIndicator
                        id="credsBusy"
                        visible="false"
                        class="sapUiLargeMarginTop"
                        size="1.5rem"
                        text="Validating credentials..."/>

                </VBox>

            </VBox>

        </HBox>

    </Page>

</mvc:View>
